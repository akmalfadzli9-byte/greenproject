/* Additional custom styles beyond Tailwind */
/* Smooth transitions for dark mode */
body {
    transition: background-color 0.3s ease, color 0.2s ease;
}

/* Modal backdrop blur */
#forgot-modal {
    transition: opacity 0.2s ease;
}

/* Custom focus rings for better accessibility */
button:focus-visible,
input:focus-visible {
    outline: 2px solid #10b981;
    outline-offset: 2px;
}

/* Dark mode scrollbar (subtle) */
@media (prefers-color-scheme: dark) {
    ::-webkit-scrollbar {
        width: 8px;
        background: #1f2937;
    }
    ::-webkit-scrollbar-thumb {
        background: #4b5563;
        border-radius: 8px;
    }
}

/* Ensure modal scrolling doesn't affect background */
.modal-open {
    overflow: hidden;
}

/* Additional hover effect on cards */
.bg-white {
    transition: box-shadow 0.2s;
}
.bg-white:hover {
    box-shadow: 0 20px 25px -12px rgba(0, 0, 0, 0.1);
}
